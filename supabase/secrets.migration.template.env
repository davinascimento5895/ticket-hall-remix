# npx supabase secrets set --project-ref wmuwctsmuagetcjqeboz --env-file supabase/secrets.migration.template.env

# Pagamentos / ASAAS
ASAAS_API_KEY=
ASAAS_BASE_URL=
ASAAS_WEBHOOK_TOKEN=
ASAAS_WEBHOOK_SECRET=

# Segurança / QR / Cron
QR_SECRET=
CRON_SECRET=

# Observacao:
# SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY
# ja sao gerenciados pelo projeto e aparecem no secrets list automaticamente.
