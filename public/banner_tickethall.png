<svg xmlns="http://www.w3.org/2000/svg" width="1600" height="600" viewBox="0 0 1200 400" fill="none">
  <rect width="1200" height="400" fill="#F6F2F2"/>
  <defs>
    <linearGradient id="g" x1="0" x2="1">
      <stop offset="0" stop-color="#FF6B4A"/>
      <stop offset="1" stop-color="#FF3A2F"/>
    </linearGradient>
  </defs>
  <rect x="0" y="0" width="1200" height="400" fill="url(#g)" opacity="0.08" rx="8"/>
  <g font-family="Inter, Sora, sans-serif" fill="#111">
    <text x="60" y="140" font-size="44" font-weight="700">TicketHall</text>
    <text x="60" y="200" font-size="28" font-weight="600" fill="#E11D48">Os melhores eventos</text>
    <text x="60" y="240" font-size="28" font-weight="700">em um só lugar</text>
  </g>
  <g transform="translate(840,60)" opacity="0.95">
    <rect width="320" height="220" rx="12" fill="#FFFFFF" opacity="0.12"/>
    <text x="20" y="120" font-family="Inter, Sora, sans-serif" font-size="20" fill="#FFF">Banner placeholder</text>
  </g>
</svg>